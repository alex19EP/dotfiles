set my_cfgdir = $HOME/.config/neomutt
set mailcap_path = $my_cfgdir/mailcap
source $my_cfgdir/sidebar
source $my_cfgdir/gpg.rc
set mbox_type = Maildir
set folder = ~/.local/share/mail
set nm_default_uri = "notmuch:///home/alex/.local/share/mail"
set send_charset = "utf-8"
auto_view text/html                                      # view html automatically
alternative_order text/plain text/enriched text/html     # save html for last
set header_cache_backend = lmdb
set header_cache = ~/.cache/neomutt
set message_cachedir = ~/.cache/neomutt
set sendmail = "/usr/bin/msmtp"
set user_agent
set forward_format = "Fwd: %s"
set pager_context = 1
set realname = "Alexander Epaneshnikov"
set use_from = yes
set envelope_from = yes
# pick reply From by which alternate the mail was addressed to (works in vfolders too)
set reverse_name = yes
alternates aarnaarn2@gmail.com email@alex19ep.me alex19ep@archlinux.org
set fast_reply = yes
set include = yes
set abort_unmodified = no
set pager_stop
set status_on_top
set beep_new
unset markers
unset mark_old
unset confirmappend
set delete
set size_show_mb
set help = no
set sleep_time = 0
set edit_headers= yes
set auto_tag = yes
set index_format='%4C %Z %<[y?%<[m?%<[d?%[%H:%M ]&%[%a %d]>&%[%b %d]>&%[%m/%y ]> %=15.25L %s'
set display_filter="$my_cfgdir/date-filter.sh"
set wait_key = no

hdr_order subject: date: from: to: cc:

bind index,pager \Cf vfolder-from-query
unbind index,pager D
bind index,pager D purge-message
macro index,pager \cv "<view-attachments><search>html<enter><view-mailcap><exit>"
macro index S "<sync-mailbox><shell-escape>$my_cfgdir/sync-mail.sh<enter>" "move trashed mail, then mbsync and notmuch new"
macro index,pager \cb "<pipe-message> urlscan<Enter>" "call urlscan to extract URLs out of a message"
macro attach,compose \cb "<pipe-entry> urlscan<Enter>" "call urlscan to extract URLs out of a message"

# sign by identity, not by folder: default off, on for personal/arch
send-hook . 'unset crypt_autosign'
send-hook '~f email@alex19ep\.me' 'set crypt_autosign'
send-hook '~f alex19ep@archlinux\.org' 'set crypt_autosign'

# gmail
folder-hook gmail/* source $my_cfgdir/accounts/gmail
macro index,pager <f3> '<sync-mailbox><enter-command>source $my_cfgdir/accounts/gmail<enter><change-folder>!<enter>'

# personal
source $my_cfgdir/accounts/email
folder-hook $folder source $my_cfgdir/accounts/email
macro index,pager <f2> '<sync-mailbox><enter-command>source $my_cfgdir/accounts/email<enter><change-folder>!<enter>'

# arch linux
folder-hook arch/* source $my_cfgdir/accounts/arch
macro index,pager <f4> '<sync-mailbox><enter-command>source $my_cfgdir/accounts/arch<enter><change-folder>!<enter>'

# admin
folder-hook admin/* source $my_cfgdir/accounts/admin
macro index,pager <f6> '<sync-mailbox><enter-command>source $my_cfgdir/accounts/admin<enter><change-folder>!<enter>'

# notmuch virtual folders (ctrl-f): use gmail account settings (identity etc.)
# kept last so it wins over accidental regex matches of the hooks above against the query text
# in vfolders 'd' tags the message deleted instead of touching files;
# sync-mail.sh later moves tagged mail to its own account's trash
folder-hook . 'bind index,pager d delete-message; bind index,pager u undelete-message'
folder-hook 'notmuch://' source $my_cfgdir/accounts/gmail
folder-hook 'notmuch://' 'macro index,pager d "<modify-labels-then-hide>+deleted -inbox -unread<enter>"; macro index,pager u "<modify-labels>-deleted<enter>"'
